# SFRS standard environment. deploy.sh copia este fichero a .env si no existe.
# Ajusta los valores por lab. NUNCA pongas secretos reales ni respuestas aquí.

# Identidad del lab (== nombre del repo). Usado como -p (proyecto compose) y red.
LAB_ID=krakensoc-lab-template

# Puertos que el lab expone al alumno (usados por doctor.sh para comprobarlos).
REQUIRED_PORTS=8080
WEB_PORT=8080

# Requisitos mínimos comprobados por doctor.sh
MIN_RAM_MB=2048
MIN_DISK_MB=4096
MIN_CPUS=2

# Timeout (segundos) que verify.sh espera a que todo esté sano
VERIFY_TIMEOUT=120
