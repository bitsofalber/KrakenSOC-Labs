# Ghost Protocol — configuración del runtime. deploy.sh la copia a .env.
LAB_ID=ghost-protocol

# Este lab no expone puertos al host: el alumno analiza el PCAP generado.
REQUIRED_PORTS=

# Dominio del C2 (parte de la investigación: aparece en la cabecera Host).
C2_DOMAIN=cdn-edge-sync.net

# Número de check-ins (beacons) que hace el implante.
BEACONS=12
# Intervalo base entre beacons (segundos); el implante añade jitter.
BEACON_INTERVAL=3
# En qué beacon el C2 entrega la tarea de exfiltración.
TASK_ON=6

# Segundos que el implante espera antes de empezar (deja arrancar al sniffer).
START_DELAY=6

# Modo instructor: si =1, el C2 reconstruye el fichero robado en ./pcaps/.
# Déjalo en 0 para los alumnos (deben decodificarlo ellos desde la captura).
INSTRUCTOR_MODE=0

# Requisitos mínimos (doctor.sh)
MIN_RAM_MB=2048
MIN_DISK_MB=4096
MIN_CPUS=2
VERIFY_TIMEOUT=180
