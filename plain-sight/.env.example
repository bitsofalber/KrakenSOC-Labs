# Plain Sight — configuración del runtime. deploy.sh la copia a .env.
LAB_ID=plain-sight

# Este lab no expone puertos al host: el alumno analiza el PCAP generado.
REQUIRED_PORTS=

# Credenciales que el empleado envía al portal legacy (parte de la investigación:
# viajan EN CLARO y aparecen en la captura).
PORTAL_USER=s.buchanan
PORTAL_PASS=S@lesManager2026

# Segundos que la workstation espera antes de empezar (deja arrancar al sniffer).
START_DELAY=6

# Requisitos mínimos (doctor.sh)
MIN_RAM_MB=2048
MIN_DISK_MB=4096
MIN_CPUS=2
VERIFY_TIMEOUT=150
