# Silent Harvest — reglas Suricata para DNS exfiltration (T1048.003 / T1071.004)
# 1) Etiqueta de subdominio anormalmente larga (base32) en una query DNS
alert dns any any -> any any (msg:"KRAKENSOC DNS Exfiltration - long base32 subdomain label"; \
  dns.query; content:"sync-telemetry-cdn.net"; nocase; \
  pcre:"/[a-z2-7]{40,}\./"; \
  classtype:policy-violation; \
  metadata:mitre_technique T1048_003, mitre_tactic TA0010; sid:9000001; rev:1;)

# 2) Volumen alto de queries al mismo dominio en poco tiempo (posible tunneling)
alert dns any any -> any any (msg:"KRAKENSOC DNS Exfiltration - high query volume to exfil domain"; \
  dns.query; content:"sync-telemetry-cdn.net"; nocase; \
  threshold:type both, track by_src, count 30, seconds 60; \
  classtype:policy-violation; \
  metadata:mitre_technique T1071_004, mitre_tactic TA0011; sid:9000002; rev:1;)
