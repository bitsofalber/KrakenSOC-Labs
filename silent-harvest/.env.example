# Silent Harvest — configuración del runtime. deploy.sh la copia a .env.
LAB_ID=silent-harvest

# Este lab no expone puertos al host: el alumno analiza el PCAP generado.
REQUIRED_PORTS=

# Dominio usado por el atacante para el DNS tunneling (parte de la investigación).
EXFIL_DOMAIN=sync-telemetry-cdn.net

# Segundos que la víctima espera antes de empezar (deja arrancar al sniffer).
START_DELAY=6

# Modo instructor: si =1, el C2 reconstruye el fichero robado en ./pcaps/.
# Déjalo en 0 para los alumnos (deben reconstruirlo ellos desde la captura).
INSTRUCTOR_MODE=0

# Requisitos mínimos (doctor.sh)
MIN_RAM_MB=2048
MIN_DISK_MB=4096
MIN_CPUS=2
VERIFY_TIMEOUT=150
