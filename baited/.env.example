# Overwatch — configuración del runtime interactivo. deploy.sh la copia a .env.
LAB_ID=baited

# Splunk Web se expone en este puerto del host (http://localhost:8000).
SPLUNK_WEB_PORT=8000
REQUIRED_PORTS=8000

# Contraseña del admin de Splunk (usuario: admin). Cámbiala si quieres.
SPLUNK_PASSWORD=Changeme123!

# Semilla del data-forge (determinista: mismas respuestas siempre).
FORGE_SEED=1566

# Requisitos mínimos (doctor.sh) — Splunk necesita bastante RAM.
MIN_RAM_MB=4096
MIN_DISK_MB=8192
MIN_CPUS=2
VERIFY_TIMEOUT=420
